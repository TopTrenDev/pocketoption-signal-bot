# --- Mode ---
# paper = fake candles, no PocketOption connection
# demo  = PocketOption demo (needs PO_SESSION + PO_UID)
# live  = real money (needs PO_LIVE_CONFIRMED=true + session/uid)
PO_MODE=demo
PO_LIVE_CONFIRMED=false

# --- PocketOption auth (required for PO_MODE=demo or live) ---
# Quick-trading WebSocket: 42["auth",{...}] -> session; 42["auth_success",{uid,...}]
PO_SESSION=
PO_UID=
PO_IS_DEMO=true
PO_REGION=DEMO

# --- Symbol & contract ---
PO_SYMBOL=EURUSD_otc
PO_TIMEFRAME_SEC=60
PO_EXPIRY_SEC=60
PO_CANDLE_COUNT=300

PO_BROWSER_URL_DEMO=https://pocketoption.com/en/cabinet/demo-quick-high-low/
PO_BROWSER_URL_LIVE=https://pocketoption.com/en/cabinet/quick-high-low/
PO_HEADLESS=false
PO_BROWSER_STARTUP_WAIT_SEC=15

PO_USE_WS_QUOTES=true

PO_CONSOLE_LOG=true
PO_BROWSER_OVERLAY=true
PO_WS_DEBUG=false


# --- Strategy (EMA + RSI) ---
PO_EMA_FAST=20
PO_EMA_SLOW=50
PO_RSI_PERIOD=14
PO_BUY_RSI_MIN=50
PO_SELL_RSI_MAX=50
# Higher = less trading around RSI 50; lower = more active
PO_RSI_NEUTRAL_BAND=1.5
# 0.0 = no EMA separation requirement (more active)
PO_MIN_EMA_GAP=0.0
# false = no momentum gate (more active)
PO_REQUIRE_MOMENTUM_CONFIRM=false
# false = strict mode only (no vote fallback)
PO_ALLOW_FALLBACK_VOTE=true
# Require same EMA trend sign for this many recent points (higher = fewer reversal entries)
PO_MIN_TREND_STREAK=2
# Chop filter window and minimum % range over that window (higher min_range_pct = fewer trades)
PO_CHOP_LOOKBACK=20
PO_MIN_RANGE_PCT=0.05
PO_MIN_ABS_EMA_DIFF=0
PO_SIGNAL_CONFIRM_POLLS=2
PO_FLIP_COOLDOWN_SEC=0

# --- Risk ---
PO_TRADE_AMOUNT=1.0
PO_MIN_PAYOUT_PCT=70
PO_MAX_SIGNAL_AGE_MS=1500
PO_MAX_CONSECUTIVE_LOSSES=3
PO_MAX_TRADES_PER_DAY=20
PO_DAILY_LOSS_STOP_PCT=2

# --- Loop ---
PO_POLL_SECONDS=2
PO_ADAPTER_PRIORITY=api_then_browser
